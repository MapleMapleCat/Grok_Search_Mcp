# grok-search-mcp 首次部署的基础配置。
# 复制为 .env 后，至少需要填写 CPA_API_KEY 和 GROK_JWT_SECRET：
#   cp .env.example .env
#
# .env 已在 .gitignore 中排除。不要提交真实凭证。
# 具有安全默认值的可选配置统一放在 advanced.env 中。

# CPA 上游地址和端口。留空时，本地二进制默认使用 http://127.0.0.1:8317，
# Docker Compose 默认使用 http://host.docker.internal:8317。
CPA_BASE_URL=

# 新数据库首次启动时必填；之后也可以由 SQLite 中的面板设置提供。
CPA_API_KEY=

# 面板 JWT 签名和敏感数据加密派生密钥，始终必填且至少 32 字节。
# 可使用以下命令生成：openssl rand -hex 32
GROK_JWT_SECRET=
